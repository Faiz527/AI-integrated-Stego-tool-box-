# ============================================================================
# MODEL FILES (Large Binary Files - Track but optimize)
# ============================================================================
# Keep existing pkl files in repo, but ignore new ones during development
# Uncomment the line below to stop tracking new pkl files
# src/detect_stego/models/*.pkl

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
