# Create clean .gitignore with no duplicates
@"
# ============================================================================
# VIRTUAL ENVIRONMENTS
# ============================================================================
venv/
ENV/
env/
.venv
env.bak/
venv.bak/
.venv-1/
venv-1/

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# IDE & EDITORS
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ============================================================================
# ENVIRONMENT VARIABLES & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# ============================================================================
# DATABASE
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.dbm

# ============================================================================
# LOGS
# ============================================================================
*.log
logs/
*.log*

# ============================================================================
# TEMPORARY FILES
# ============================================================================
temp/
tmp/
*.tmp
*.temp
*.bak
*.backup
~*

# ============================================================================
# STREAMLIT
# ============================================================================
.streamlit/secrets.toml
streamlit_cache/

# ============================================================================
# TESTING & COVERAGE
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============================================================================
# JUPYTER NOTEBOOKS
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================================
# MACHINE LEARNING MODELS (Large Binary Files)
# ============================================================================
# Don't track trained model files - they should be generated locally
src/detect_stego/models/*.pkl
src/detect_stego/models/*.joblib
*.pkl
*.joblib

# ============================================================================
# MODEL CHECKPOINTS
# ============================================================================
*.pt
*.pth
*.h5
*.model

# ============================================================================
# OS SPECIFIC
# ============================================================================
Thumbs.db
.Thumbs.db
.AppleDouble
.LSOverride
._*

# ============================================================================
# CACHE & COMPILED
# ============================================================================
.cache/
*.cache
dist/
build/
"@ | Out-File -Encoding UTF8 .gitignore

# Verify the file
Get-Content .gitignore